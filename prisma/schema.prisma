// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id            String         @id @default(cuid())
  title         String
  description   String
  fullDetails   String
  date          DateTime
  endDate       DateTime?      // Optional end date/time for events
  location      String
  fees          Json           @default("[]") // Store fees as JSON array e.g., [{"name":"Adult","price":50}]
  pdfUrl        String?        // Optional field for the PDF link
  registrationEndDate DateTime // New field for the deadline
  type          String         @default("keine")
  isPremier     Boolean        @default(false)
  isEloRequired Boolean        @default(true) // Whether ELO is required for registration
  isTeamMode    Boolean        @default(false) // Whether the event is a team tournament
  minTeamSize   Int            @default(2)
  maxTeamSize   Int            @default(4)
  customFields  String         @default("")
  emailText     String         @default("") // Custom email text for registration confirmations
  organiserEmail String?       // Optional organiser email for BCC on registrations
  registrations Registration[]
  teams         Team[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Team {
  id                String         @id @default(cuid())
  name              String
  contactEmail      String
  feeCategory       String         @default("Standard")
  isPubliclyVisible Boolean        @default(true)
  additionalInfo    Json
  event             Event          @relation(fields: [eventId], references: [id])
  eventId           String
  members           Registration[]
  createdAt         DateTime       @default(now())
}

model Registration {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  birthYear Int
  verein    String   @default("")
  elo       Int      @default(0) // DWZ rating
  fideElo   Int      @default(0) // FIDE-Elo rating
  feeCategory String   @default("Standard") // To store which fee the user selected
  additionalInfo Json
  isPubliclyVisible Boolean @default(true) // Whether the registration should be visible in public lists

  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
  team      Team?    @relation(fields: [teamId], references: [id])
  teamId    String?
  createdAt DateTime @default(now())
}